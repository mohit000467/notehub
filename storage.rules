// storage.rules
// ============================================================
// Firebase Storage Security Rules
// Deploy with: firebase deploy --only storage
// ============================================================

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    match /notes/{userId}/{fileName} {
      // Anyone can read/download files
      allow read: if true;

      // Only authenticated users can upload to their own folder
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 25 * 1024 * 1024  // Max 25MB
                   && (
                     request.resource.contentType.matches('application/pdf')
                     || request.resource.contentType.matches('application/msword')
                     || request.resource.contentType.matches('application/vnd.openxmlformats.*')
                     || request.resource.contentType.matches('image/.*')
                     || request.resource.contentType.matches('application/vnd.ms-powerpoint')
                   );

      // Only owner can delete their files
      allow delete: if request.auth != null
                    && request.auth.uid == userId;
    }
  }
}
