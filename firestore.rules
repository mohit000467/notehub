rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "mohitsingh97941111@gmail.com";
    }

    match /users/{userId} {
      allow read: if isAdmin()
        || resource.data.profileVisibility == 'public'
        || request.auth.uid == userId;

      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
        || isAdmin();
      allow delete: if isAdmin();
    }

    match /notes/{noteId} {
      allow read: if true;
      allow delete: if isAdmin()
        || (request.auth != null && resource.data.userId == request.auth.uid);

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['rating', 'ratingSum', 'ratingCount', 'ratedBy', 'downloadCount'])
        || isAdmin()
      );
    }

    match /config/{docId} {
      allow read, write: if isAdmin();
    }

    // Login attempt tracking — unauthenticated bhi access kar sake
    match /loginAttempts/{docId} {
      allow read, write: if true;
    }
  }
}